{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/guide/**",
              "ui_kits/travel-guide/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader))/i]",
        "message": "Font not provided by the design system. Available: Newsreader."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|className|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, size, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|outline|muted|edition)$/]",
        "message": "<Badge> variant must be one of 'gold' | 'outline' | 'muted' | 'edition'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|as|className|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, as, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|solid|outline|ghost|paper)$/]",
        "message": "<Button> variant must be one of 'primary' | 'solid' | 'outline' | 'ghost' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|pad|gilt|interactive|className|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, pad, gilt, interactive, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|panel|paper|flat)$/]",
        "message": "<Card> variant must be one of 'default' | 'panel' | 'paper' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Card> pad must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:from|name|time|read|className|children|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: from, name, time, read, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='from'] > Literal[value!=/^(?:guide|you)$/]",
        "message": "<ChatBubble> from must be one of 'guide' | 'you'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|soft|className|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: label, soft, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='FoilText'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|className|children|key|ref|className|style|children)$/]",
        "message": "<FoilText> doesn't accept that prop. Declared props: as, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|className|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Label'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|tick|className|children|key|ref|className|style|children)$/]",
        "message": "<Label> doesn't accept that prop. Declared props: tone, tick, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Label'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|secondary|paper)$/]",
        "message": "<Label> tone must be one of 'gold' | 'secondary' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LessonChoice'] > JSXAttribute > JSXIdentifier[name!=/^(?:choiceKey|state|className|children|key|ref|className|style|children)$/]",
        "message": "<LessonChoice> doesn't accept that prop. Declared props: choiceKey, state, className, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='LessonChoice'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:default|selected|correct|wrong)$/]",
        "message": "<LessonChoice> state must be one of 'default' | 'selected' | 'correct' | 'wrong'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|className|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: variant, size, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:white|foil)$/]",
        "message": "<Logo> variant must be one of 'white' | 'foil'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:face|flippable|width|location|season|subject|hook|artSrc|flagSrc|story|body|edition|archiveId|signature|qrSrc|className|style|key|ref|className|style|children)$/]",
        "message": "<StoryCard> doesn't accept that prop. Declared props: face, flippable, width, location, season, subject, hook, artSrc, flagSrc, story, body, edition, archiveId, signature, qrSrc, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryCard'] > JSXAttribute[name.name='face'] > Literal[value!=/^(?:front|back)$/]",
        "message": "<StoryCard> face must be one of 'front' | 'back'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StoryMoment'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|title|artSrc|collectible|collectLabel|onCollect|className|children|key|ref|className|style|children)$/]",
        "message": "<StoryMoment> doesn't accept that prop. Declared props: label, title, artSrc, collectible, collectLabel, onCollect, className, children."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
